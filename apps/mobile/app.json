{
  "expo": {
    "name": "FlowOps",
    "slug": "flowops-mobile",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "flowops",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/flowops-icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flowops.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/flowops-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.flowops.app",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-asset",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "28ceb1a7-d3f9-43d4-bc80-4c79926ee066"
      }
    },
    "owner": "luis.champs"
  }
}
