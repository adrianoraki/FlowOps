rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return userDoc().role;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isGestor() {
      return role() == 'gestor';
    }

    function isTecnico() {
      return role() == 'tecnico';
    }

    function meusEstados() {
      return userDoc().estados;
    }

    // ─── users/{uid} ──────────────────────────────────────────────────────────
    //
    // Criação de usuários (técnicos) é feita pelo admin/gestor via Auth secundário.
    // Deleção não existe: usamos ativo=false.

    match /users/{uid} {
      allow read: if isSignedIn() &&
        (request.auth.uid == uid || isAdmin() || isGestor());

      allow create: if isSignedIn() && (isAdmin() || isGestor());

      allow update: if isSignedIn() && (isAdmin() || isGestor())
        // Impede autopromocão: ninguém muda o próprio role (exceto admin)
        && (isAdmin()
            || request.auth.uid != uid
            || request.resource.data.role == resource.data.role);

      allow delete: if false;
    }

    // ─── parceiros/{id} ───────────────────────────────────────────────────────

    match /parceiros/{id} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isGestor());
    }

    // ─── lojas/{id} ───────────────────────────────────────────────────────────
    //
    // Loja de um parceiro (rede ou único). estado/regiao da loja alimentam a OS.

    match /lojas/{id} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isGestor());
    }

    // ─── pecas/{id} ───────────────────────────────────────────────────────────

    match /pecas/{id} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isGestor());
    }

    // ─── setores/{id} ─────────────────────────────────────────────────────────
    //
    // Cadastro de setores por empresa (white-label), gerenciado em /configuracoes.

    match /setores/{id} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }

    // ─── modelos/{id} ─────────────────────────────────────────────────────────
    //
    // Catálogo de modelos de balança por empresa (white-label), gerenciado em /configuracoes.

    match /modelos/{id} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isGestor());
    }

    // ─── balancas/{id} ────────────────────────────────────────────────────────
    //
    // FUNDAÇÃO: parque de balanças por loja (ver CLAUDE.md > "Balanças / Equipamentos").
    // Ainda sem telas de cadastro/edição/listagem — só a coleção + esta regra existem.

    match /balancas/{id} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isGestor());
    }

    // ─── config/{id} ──────────────────────────────────────────────────────────
    //
    // Leitura pública para que a tela de login exiba nome e logo da empresa
    // antes da autenticação. Escrita restrita a admin.

    match /config/{id} {
      allow read:  if true;
      allow write: if isSignedIn() && isAdmin();
    }

    // ─── counters/{id} ────────────────────────────────────────────────────────
    //
    // Numeração sequencial de OS via transação client-side (sem Cloud Functions).

    match /counters/{id} {
      allow read:   if isSignedIn() && (isAdmin() || isGestor());
      // create cobre o primeiro uso (doc counters/ordens ainda não existe) dentro
      // da mesma transação que cria a OS — quem cria OS também pode criar o contador.
      allow create: if isSignedIn() && (isAdmin() || isGestor());
      allow update: if isSignedIn() && (isAdmin() || isGestor());
      allow delete: if false;
    }

    // ─── ordens_servico/{id} ──────────────────────────────────────────────────
    //
    // Trilha de auditoria INMETRO: status 'concluida' e 'cancelada' são
    // imutáveis para todos exceto admin (que pode corrigir erros).

    match /ordens_servico/{id} {
      allow read: if isSignedIn() && (
        isAdmin() || isGestor() ||
        (isTecnico() && (
          resource.data.estado    in meusEstados() ||
          resource.data.tecnicoId == request.auth.uid
        ))
      );

      allow create: if isSignedIn() && (isAdmin() || isGestor());

      // Cobre TODAS as transições de status enquanto a OS não está encerrada —
      // inclusive em_andamento <-> aguardando_peca (pausar/retomar por falta de
      // peça), feitas pelo técnico dono ou por admin/gestor. Não há uma regra
      // por-transição: qualquer update é permitido enquanto o status ATUAL não é
      // 'concluida'/'cancelada' (a imutabilidade da OS encerrada é o que importa
      // para a trilha de auditoria INMETRO).
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isGestor() &&
          resource.data.status != 'concluida' &&
          resource.data.status != 'cancelada') ||
        (isTecnico() &&
          resource.data.tecnicoId == request.auth.uid &&
          resource.data.status    != 'concluida' &&
          resource.data.status    != 'cancelada')
      );

      allow delete: if isSignedIn() && isAdmin();
    }

    // ─── movimentacoes/{id} ───────────────────────────────────────────────────
    //
    // Dupla confirmação: quem cria NÃO pode confirmar a própria movimentação.
    // Envio (admin/gestor cria) → técnico destinatário confirma.
    // Devolucao (técnico cria)  → admin/gestor confirma.

    match /movimentacoes/{id} {
      allow read: if isSignedIn() && (
        isAdmin() || isGestor() ||
        (isTecnico() && (
          resource.data.tecnicoId   == request.auth.uid ||
          resource.data.criadoPorId == request.auth.uid
        ))
      );

      allow create: if isSignedIn()
        && request.resource.data.criadoPorId == request.auth.uid
        && request.resource.data.status      == 'pendente';

      allow update: if isSignedIn()
        // Só muda status pendente → confirmada | divergencia
        && resource.data.status          == 'pendente'
        && request.resource.data.status  in ['confirmada', 'divergencia']
        // Confirmador não pode ser o criador
        && request.auth.uid              != resource.data.criadoPorId
        // Apenas os campos permitidos mudam
        && request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(['status', 'confirmadoPorId', 'confirmadoEm', 'observacao'])
        && (
          // Envio: confirmado pelo técnico destinatário
          (resource.data.tipo == 'envio' &&
           isTecnico() &&
           resource.data.tecnicoId == request.auth.uid)
          ||
          // Devolucao: confirmada por admin ou gestor
          (resource.data.tipo == 'devolucao' && (isAdmin() || isGestor()))
        );

      allow delete: if false;
    }

    // ─── estoque_tecnico/{id} ─────────────────────────────────────────────────
    //
    // Saldo calculado — nunca editar à mão fora da transação de confirmação.
    // Sem Cloud Functions, a consistência depende da transação client-side em
    // Estoque.tsx + estas regras. Admin/gestor podem corrigir saldos manualmente.
    // Técnico pode gravar seu próprio saldo (necessário na transação de envio).

    match /estoque_tecnico/{id} {
      allow read: if isSignedIn() && (
        isAdmin() || isGestor() ||
        (isTecnico() && resource.data.tecnicoId == request.auth.uid)
      );

      allow create: if isSignedIn() && (
        isAdmin() || isGestor() ||
        (isTecnico() && request.resource.data.tecnicoId == request.auth.uid)
      );

      allow update: if isSignedIn() && (
        isAdmin() || isGestor() ||
        (isTecnico() && resource.data.tecnicoId == request.auth.uid)
      );

      allow delete: if isSignedIn() && isAdmin();
    }

    // ─── selos/{id} ───────────────────────────────────────────────────────────
    //
    // Controle de selos INMETRO — cada documento é um selo físico individual
    // (não uma quantidade). Cadastro/envio/edição de status: admin ou gestor.
    // Técnico só lê os selos já enviados a ele (tecnicoId == uid) — não cria,
    // não edita, não vê o estoque disponível nem os selos de outros técnicos.

    match /selos/{id} {
      allow read: if isSignedIn() && (
        isAdmin() || isGestor() ||
        (isTecnico() && resource.data.tecnicoId == request.auth.uid)
      );
      allow write: if isSignedIn() && (isAdmin() || isGestor());
    }

    // ─── solicitacoesSelo/{id} ────────────────────────────────────────────────
    //
    // Pedido do técnico por mais selos. Técnico só cria pra si mesmo (com
    // status inicial 'pendente') e só lê as próprias — não edita nem apaga,
    // nem as próprias nem as de outros técnicos. Quem atende/edita é admin ou
    // gestor (ex: marcar como 'atendida' depois de enviar selos pela tela de
    // envio — não há vínculo automático entre a solicitação e um envio).

    match /solicitacoesSelo/{id} {
      allow read: if isSignedIn() && (
        isAdmin() || isGestor() ||
        (isTecnico() && resource.data.tecnicoId == request.auth.uid)
      );

      allow create: if isSignedIn() && (
        isAdmin() || isGestor() ||
        (isTecnico() &&
          request.resource.data.tecnicoId == request.auth.uid &&
          request.resource.data.status    == 'pendente')
      );

      allow update: if isSignedIn() && (isAdmin() || isGestor());
      allow delete: if isSignedIn() && isAdmin();
    }

  }
}
